<script>
  // ==========================================
  // 【運用ロジック】URLから現在のモードを動的判定
  // ==========================================
  const CURRENT_MODE = (function() {
    const params = new URLSearchParams(window.location.search);
    const mode = params.get('mode');
    const validModes = ['omiya', 'shibaura', 'normal', 'spare'];
    return validModes.includes(mode) ? mode : 'normal';
  })();

  // ==========================================
  // 【設定領域】データ外部読み込み用API URL
  // ==========================================
  const API_URL = ""; 

  // ==========================================
  // デフォルト（フォールバック用）データ構造
  // ==========================================
  const commonQuestions = [
    {
      id: "entry.111111111", type: "select", label: "あなたの属性（該当するもの） <span style='color:var(--error-red);'>*</span>", required: true,
      options: [
        { label: "選択してください", value: "" }, { label: "小学生以下", value: "小学生以下" }, { label: "中学生", value: "中学生" },
        { label: "高校生", value: "高校生" }, { label: "大学生", value: "大学生" }, { label: "一般", value: "一般" }, { label: "その他", value: "その他" }
      ]
    },
    {
      id: "entry.444444444", type: "select", label: "学部・学科・専攻（任意）", required: false, dependsOn: { id: "entry.111111111", value: "大学生" },
      options: [
        { label: "選択してください", value: "" }, { label: "土木・都市・環境系", value: "土木・都市・環境系" }, { label: "建築系", value: "建築系" },
        { label: "機械工学系", value: "機械工学系" }, { label: "電気電子・情報工学系", value: "電気電子・情報工学系" }, { label: "化学・生命・物質系", value: "化学・生命・物質系" },
        { label: "理学・数学系", value: "理学・数学系" }, { label: "文系・その他学部", value: "文系・その他学部" }, { label: "その他", value: "その他" }
      ]
    },
    { id: "entry.888888888", type: "text", label: "学部・系統名（自由記述）", required: false, dependsOn: { id: "entry.444444444", value: "その他" }, placeholder: "学部・系統名をご記入ください" }
  ];

  const modeSpecificQuestions = {
    omiya: { id: "entry.222222222", type: "textarea", label: "大宮祭への期待や感想（任意）", required: false, placeholder: "ご自由に記入してください" },
    shibaura: { id: "entry.666666666", type: "textarea", label: "芝浦祭への期待や感想（任意）", required: false, placeholder: "ご自由に記入してください" },
    normal: {
      id: "entry.555555555", type: "select", label: "このサイトをどこで知りましたか？ <span style='color:var(--error-red);'>*</span>", required: true,
      options: [
        { label: "選択してください", value: "" }, { label: "SNS (X / Instagram)", value: "SNS(X/Instagram)" }, { label: "知人の紹介", value: "知人の紹介" },
        { label: "Google / Yahoo! 等の検索", value: "検索サイト" }, { label: "学内掲示・配布物", value: "学内掲示・配布物" }, { label: "その他", value: "その他" }
      ]
    },
    spare: { id: "entry.777777777", type: "textarea", label: "本診断へのご意見・ご要望（任意）", required: false, placeholder: "テスト用・予備用のフリー入力欄です" }
  };

  let appData = {
    formUrl: "https://docs.google.com/forms/u/0/d/e/XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX/formResponse",
    resultCodeEntryId: "entry.333333333",
    shareSettings: {
      url: "https://example.com/cbti", 
      xDefaultText: "土木16タイプ診断（CBTI）をやりました！私の結果は",
      hashtags: "CBTI,大宮祭,土木"
    },
    step1Questions: {
