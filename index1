  // ==========================================
  // アプリケーションロジック（エラー回避の安全装置付き）
  // ==========================================

  async function loadAppData() {
    if (API_URL) {
      try {
        const response = await fetch(API_URL);
        
        // GAS設定ミスでログイン画面（HTML）が返ってきた場合のエラー検知
        const contentType = response.headers.get("content-type");
        if (contentType && contentType.indexOf("application/json") === -1) {
            throw new Error("GASがJSONではなくHTMLを返しました。公開設定が「全員(Anyone)」になっているか確認してください。");
        }

        const data = await response.json();
        
        // データ型が正しい場合のみ上書きする（データ破損時のフリーズ防止）
        if (data.formUrl) appData.formUrl = data.formUrl;
        if (data.resultCodeEntryId) appData.resultCodeEntryId = data.resultCodeEntryId;
        if (data.step1Questions && typeof data.step1Questions === 'object') appData.step1Questions = data.step1Questions;
        if (data.step2Questions && Array.isArray(data.step2Questions)) appData.step2Questions = data.step2Questions;
        if (data.resultsData) appData.resultsData = data.resultsData;
        if (data.shareSettings) appData.shareSettings = data.shareSettings;

      } catch (error) {
        console.error("外部データの読み込みエラー:", error);
        alert("データの読み込みに失敗したため、初期設定データで起動します。\n詳細: " + error.message);
      }
    }
    
    // 描画処理でエラーが起きても必ずローディング画面を消すための try-catch
    try {
      renderStep1();
    } catch(e) { console.error("Step1描画エラー:", e); }

    try {
      renderStep2();
    } catch(e) { console.error("Step2描画エラー:", e); }
    
    try {
      if (appData.shareSettings && appData.shareSettings.hashtags) {
        const displayHashtags = appData.shareSettings.hashtags.split(',').map(tag => `#${tag.trim()}`).join(' ');
        document.getElementById('share-hashtags').textContent = displayHashtags;
      }
    } catch(e) { console.error("ハッシュタグ処理エラー:", e); }

    // 【重要】絶対にローディング画面を隠す
    const loadingScreen = document.getElementById('loading-screen');
    if (loadingScreen) loadingScreen.style.display = 'none';
  }

  function renderStep1() {
    const container = document.getElementById('step1-dynamic-container');
    if (!container) return;
    let html = '';
    const currentQuestions = appData.step1Questions[CURRENT_MODE];

    // もしGASから不正なデータが来てモードが見つからない場合は終了
    if (!currentQuestions || !Array.isArray(currentQuestions)) {
      console.error("現在のモードに対応する質問データがありません:", CURRENT_MODE);
      return;
    }

    currentQuestions.forEach(q => {
      const isDependent = q.dependsOn ? true : false;
      const initialDisplay = isDependent ? 'none' : 'block';
      const dependentClass = isDependent ? 'dependent-field' : '';
      
      html += `<div class="form-group ${dependentClass}" id="wrapper-${q.id}" style="display: ${initialDisplay};">`;
      html += `<label for="${q.id}" class="form-label">${q.label}</label>`;
      
      const onChangeAttr = `onchange="checkVisibility(); clearStep1Error('${q.id}')" oninput="checkVisibility(); clearStep1Error('${q.id}')"`;

      if (q.type === 'select') {
        html += `<select id="${q.id}" name="${q.id}" class="form-control" ${onChangeAttr}>`;
        if (q.options) {
          q.options.forEach(opt => {
            const val = opt.value;
            const isSelected = val === "" ? "disabled selected" : "";
            html += `<option value="${val}" ${isSelected}>${opt.label}</option>`;
          });
        }
        html += `</select>`;
      } else if (q.type === 'textarea') {
        html += `<textarea id="${q.id}" name="${q.id}" class="form-control" placeholder="${q.placeholder || ''}" ${onChangeAttr}></textarea>`;
      } else {
        html += `<input type="${q.type}" id="${q.id}" name="${q.id}" class="form-control" placeholder="${q.placeholder || ''}" ${onChangeAttr}>`;
      }
      html += `</div>`;
    });

    container.innerHTML = html;
    checkVisibility();
  }

  function checkVisibility() {
    const currentQuestions = appData.step1Questions[CURRENT_MODE];
    if (!currentQuestions || !Array.isArray(currentQuestions)) return;

    currentQuestions.forEach(q => {
      const wrapper = document.getElementById(`wrapper-${q.id}`);
      const el = document.getElementById(q.id);
      let isVisible = true;

      if (q.dependsOn) {
        const parentEl = document.getElementById(q.dependsOn.id);
        if (parentEl && parentEl.value === q.dependsOn.value) {
          isVisible = true;
        } else {
          isVisible = false;
          if (el) el.value = '';
        }
      }

      if (wrapper) {
        wrapper.style.display = isVisible ? 'block' : 'none';
        if (isVisible && !wrapper.classList.contains('slide-down-fade')) {
          wrapper.classList.add('slide-down-fade');
        }
      }
    });
  }

  function clearStep1Error(id) {
    const el = document.getElementById(id);
    if (el) el.style.borderColor = '';
  }

  function goToStep2() {
    let isValid = true;
    const currentQuestions = appData.step1Questions[CURRENT_MODE];
    if (!currentQuestions) return;
    
    currentQuestions.forEach(q => {
      const wrapper = document.getElementById(`wrapper-${q.id}`);
      const el = document.getElementById(q.id);
      
      // GASの設定ミスでrequiredが文字列の "true" / "false" になった時のための安全処理
      const isReq = (q.required === true || String(q.required).toLowerCase() === "true");

      if (wrapper && wrapper.style.display !== 'none' && isReq) {
        if (el && !el.value.trim()) {
          isValid = false;
          el.style.borderColor = 'var(--error-red)';
        } else if (el) {
          el.style.borderColor = '';
        }
      }
    });

    if (!isValid) {
      alert("必須項目が入力されていません。赤枠の項目をご確認ください。");
      return;
    }

    document.getElementById('step1-area').style.display = 'none';
    document.getElementById('step2-area').style.display = 'block';
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  function renderStep2() {
    const container = document.getElementById('questions-container');
    if (!container) return;
    let html = '';

    if (!appData.step2Questions || !Array.isArray(appData.step2Questions)) return;

    appData.step2Questions.forEach((q) => {
      html += `
        <div class="content-card question-card" id="card-${q.id}">
          <div class="question-text">${q.text}</div>
          <div class="scale-container">
            ${[1, 2, 3, 4, 5].map(val => {
              let sizeClass = "size-S";
              if(val === 1 || val === 5) sizeClass = "size-L";
              else if(val === 2 || val === 4) sizeClass = "size-M";
              
              return `
              <label class="scale-option" onclick="clearStep2Error('${q.id}')">
                <input type="radio" name="${q.id}" value="${val}">
                <div class="scale-bubble ${sizeClass}"></div>
                <div class="scale-label-wrapper">
                  <div class="scale-label">${val === 1 ? '全くそう\n思わない' : val === 5 ? '非常に\nそう思う' : ''}</div>
                </div>
              </label>
              `;
            }).join('')}
          </div>
        </div>
      `;
    });
    container.innerHTML = html;
  }

  function clearStep2Error(id) {
    const el = document.getElementById(`card-${id}`);
    if (el) el.classList.remove('error');
  }

  function submitQuiz() {
    let allAnswered = true;
    let scores = { S:0, U:0, A:0, C:0, L:0, F:0, P:0, M:0 };
    let counts = { S:0, U:0, A:0, C:0, L:0, F:0, P:0, M:0 };
    let userAnswers = {};

    if (!appData.step2Questions) return;

    appData.step2Questions.forEach(q => {
      const selected = document.querySelector(`input[name="${q.id}"]:checked`);
      const card = document.getElementById(`card-${q.id}`);
      
      if (!selected) {
        if(card) card.classList.add('error');
        allAnswered = false;
      } else {
        if(card) card.classList.remove('error');
        const val = parseInt(selected.value);
        scores[q.axis] += val;
        counts[q.axis] += 1;
        userAnswers[q.id] = val;
      }
    });

    if (!allAnswered) {
      alert("未回答の質問があります。赤枠の質問にご回答ください。");
      const errEl = document.querySelector('.question-card.error');
      if (errEl) errEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
      return;
    }

    let type = "";
    type += (scores.S / (counts.S || 1)) >= (scores.U / (counts.U || 1)) ? "S" : "U";
    type += (scores.A / (counts.A || 1)) >= (scores.C / (counts.C || 1)) ? "A" : "C";
    type += (scores.L / (counts.L || 1)) >= (scores.F / (counts.F || 1)) ? "L" : "F";
    type += (scores.P / (counts.P || 1)) >= (scores.M / (counts.M || 1)) ? "P" : "M";

    sendToGoogleForm(userAnswers, appData.resultsData[type].pdfCode);
    showResult(type);
  }

  function sendToGoogleForm(step2Answers, resultCode) {
    const form = document.createElement('form');
    form.action = appData.formUrl;
    form.method = 'POST';
    form.target = 'hidden_iframe';
    form.style.display = 'none';

    const addInput = (name, value) => {
      if (!name) return;
      const input = document.createElement('input');
      input.type = 'hidden';
      input.name = name;
      input.value = value;
      form.appendChild(input);
    };

    const currentQuestions = appData.step1Questions[CURRENT_MODE];
    if (currentQuestions) {
      currentQuestions.forEach(q => {
        const el = document.getElementById(q.id);
        const wrapper = document.getElementById(`wrapper-${q.id}`);
        if (el && wrapper && wrapper.style.display !== 'none') {
          addInput(q.id, el.value);
        }
      });
    }

    Object.keys(step2Answers).forEach(entryId => {
      addInput(entryId, step2Answers[entryId]);
    });

    addInput(appData.resultCodeEntryId, resultCode);

    document.body.appendChild(form);
    form.submit();
    document.body.removeChild(form);
  }

  function showResult(type) {
    document.getElementById("step2-area").style.display = "none";
    const result = appData.resultsData[type];
    const ra = document.getElementById("result-area");
    if (!ra || !result) return;

    ra.style.display = "block";
    window.scrollTo({ top: 0, behavior: 'smooth' });

    document.getElementById("result-hero").style.background = result.color;
    document.getElementById("result-code").textContent = result.pdfCode + " タイプ";
    document.getElementById("result-name").textContent = result.name;
    document.getElementById("result-description").textContent = result.desc;
    document.getElementById("result-job-text").innerHTML = result.job.replace(/\n/g, '<br>');
    
    const triviaText = result.trivia || "土木の世界は奥が深い！";
    document.getElementById("result-trivia-text").innerHTML = triviaText.replace(/\n/g, '<br>');

    window.currentResult = result;
  }

  function shareToX() {
    const result = window.currentResult;
    if (!result) return;
    
    const text = `${appData.shareSettings.xDefaultText}「${result.name}」でした！\n\n`;
    const url = appData.shareSettings.url;
    const hashtags = appData.shareSettings.hashtags;
    
    const tweetContent = encodeURIComponent(`${text}\n${url}`);
    const hashtagQuery = hashtags ? `&hashtags=${encodeURIComponent(hashtags)}` : "";
    
    const webUrl = `https://twitter.com/intent/tweet?text=${tweetContent}${hashtagQuery}`;
    window.open(webUrl, '_blank');
  }

  function shareToInstagram() {
    const resultArea = document.getElementById('result-area');
    const hashTags = document.getElementById('share-hashtags');
    const actionButtons = document.querySelector('.action-buttons');
    
    hashTags.style.display = 'block';
    actionButtons.style.display = 'none';
    const originalPadding = resultArea.style.paddingBottom;
    resultArea.style.paddingBottom = "30px";

    html2canvas(resultArea, { 
      scale: 2,
      useCORS: true,
      backgroundColor: "#ffffff" 
    }).then(canvas => {
      hashTags.style.display = 'none';
      actionButtons.style.display = 'block';
      resultArea.style.paddingBottom = originalPadding;
      
      const link = document.createElement('a');
      link.download = 'cbti_result.png';
      link.href = canvas.toDataURL('image/png');
      link.click();

      setTimeout(() => {
        window.location.href = "instagram://camera";
      }, 500);

    }).catch(err => {
      console.error("画像生成エラー:", err);
      alert("画像の生成に失敗しました。");
      hashTags.style.display = 'none';
      actionButtons.style.display = 'block';
      resultArea.style.paddingBottom = originalPadding;
    });
  }

  // ページ読み込み開始
  window.onload = loadAppData;
</script>
