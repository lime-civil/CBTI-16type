      shibaura: [...commonQuestions, modeSpecificQuestions.shibaura],
      normal: [...commonQuestions, modeSpecificQuestions.normal],
      spare: [...commonQuestions, modeSpecificQuestions.spare]
    },
    step2Questions: [
      { id: "entry.100000001", axis: "S", text: "Q1. 巨大な橋やダムの迫力ある姿を見ると、「どうやって作られているんだろう？」と細部まで見入ってしまう。" },
