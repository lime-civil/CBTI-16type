<style>
  :root {
    --blue-deep: #1a3a5c;
    --blue-mid:  #2563a8;
    --blue-light: #4a9fd4;
    --blue-pale: #dbeeff;
    --blue-ultra: #f0f7ff;
    --white: #ffffff;
    --gray-soft: #8fa3b8;
    --gray-line: #d8e8f5;
    --text-main: #1a2e44;
    --text-sub: #5a7a96;
    --error-red: #e74c3c;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'Noto Sans JP', sans-serif;
    background: linear-gradient(160deg, #e8f3ff 0%, #f6faff 50%, #eef6ff 100%);
    min-height: 100vh;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding: 20px 10px 20px;
  }

  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image:
      linear-gradient(rgba(37,99,168,0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(37,99,168,0.05) 1px, transparent 1px);
    background-size: 40px 40px;
    pointer-events: none;
    z-index: 0;
  }

  #app-container {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 600px;
  }

  /* ── ローディング画面 ── */
  #loading-screen {
    position: fixed;
    inset: 0;
    background: rgba(255, 255, 255, 0.9);
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    z-index: 9999;
    color: var(--blue-mid);
    font-weight: 700;
  }
  .spinner {
    width: 40px; height: 40px;
    border: 4px solid var(--blue-pale);
    border-top-color: var(--blue-mid);
    border-radius: 50%;
    animation: spin 1s linear infinite;
    margin-bottom: 15px;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* ── Header ── */
  .app-header {
    text-align: center;
    margin-bottom: 24px;
    animation: fadeSlideDown 0.5s ease both;
  }
  .app-header .label-eng {
    display: inline-block;
    font-family: 'Josefin Sans', sans-serif;
    font-size: 0.7em;
    font-weight: 600;
    letter-spacing: 0.2em;
    color: var(--blue-light);
    text-transform: uppercase;
    margin-bottom: 4px;
  }
  .app-header h1 {
    font-family: 'Josefin Sans', sans-serif;
    font-size: clamp(1.4em, 4.5vw, 2em);
    font-weight: 700;
    color: var(--blue-deep);
  }
  .app-header h1 span { color: var(--blue-mid); }
  .app-header .subtitle {
    margin-top: 4px;
    font-size: 0.8em;
    color: var(--text-sub);
  }

  /* ── 共通カードスタイル ── */
  .content-card {
    background: var(--white);
    border-radius: 16px;
    box-shadow: 0 4px 20px rgba(26,58,92,0.06);
    padding: 24px 20px;
    margin-bottom: 20px;
  }

  /* ── Step 1: アンケート ── */
  #step1-area {
    animation: fadeSlideUp 0.5s ease both;
  }
  .form-group { margin-bottom: 20px; }
  .form-label {
    display: block;
    font-size: 0.95em;
    font-weight: 700;
    color: var(--blue-deep);
    margin-bottom: 8px;
  }
  .form-control {
    width: 100%;
    padding: 12px 15px;
    font-size: 1em;
    font-family: inherit;
    color: var(--text-main);
    border: 2px solid var(--gray-line);
    border-radius: 8px;
    background-color: #fafcfd;
    transition: border-color 0.3s;
  }
  .form-control:focus {
    outline: none;
    border-color: var(--blue-mid);
    background-color: var(--white);
  }
  textarea.form-control {
    resize: vertical;
    min-height: 100px;
  }

  /* 条件付きで表示されるフィールドのデザイン */
  .dependent-field {
    margin-top: -10px;
    padding-top: 10px;
    border-top: 1px dashed var(--gray-line);
  }
  .slide-down-fade { animation: slideDownFade 0.4s cubic-bezier(0.16, 1, 0.3, 1) both; }

  /* ── Step 2: 診断問題 ── */
  #step2-area {
    display: none;
    animation: fadeSlideUp 0.5s ease both;
  }
  .question-card {
    border: 2px solid transparent;
    transition: border-color 0.3s;
    padding-bottom: 50px; 
  }
  .question-card.error {
    border-color: var(--error-red);
    background-color: #fffaf9;
  }
  .question-text {
    font-size: 0.95em;
    font-weight: 700;
    color: var(--text-main);
    line-height: 1.6;
    margin-bottom: 24px;
  }

  /* ── 5-Point Scale UI ── */
  .scale-container {
    position: relative;
    display: flex;
    justify-content: space-between;
    align-items: center; 
    padding: 0 5px;
    height: 60px; 
  }
  .scale-container::before {
    content: '';
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    left: 20px;
    right: 20px;
    height: 4px;
    background: var(--gray-line);
    z-index: 0;
    border-radius: 2px;
  }
  .scale-option {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    cursor: pointer;
    width: 18%;
  }
  .scale-option input[type="radio"] {
    position: absolute;
    opacity: 0;
    cursor: pointer;
  }
  .scale-bubble {
    border-radius: 50%;
    background: var(--white);
    border: 3px solid var(--blue-pale);
    transition: all 0.2s cubic-bezier(.4,0,.2,1);
    box-shadow: 0 2px 5px rgba(0,0,0,0.05);
  }
  .scale-bubble.size-L { width: 52px; height: 52px; }
  .scale-bubble.size-M { width: 42px; height: 42px; }
  .scale-bubble.size-S { width: 32px; height: 32px; }

  @media (max-width: 400px) {
    .scale-bubble.size-L { width: 44px; height: 44px; }
    .scale-bubble.size-M { width: 36px; height: 36px; }
    .scale-bubble.size-S { width: 28px; height: 28px; }
  }

  .scale-option input[type="radio"]:checked + .scale-bubble {
    background: var(--blue-mid);
    border-color: var(--blue-mid);
    transform: scale(1.15);
    box-shadow: 0 4px 12px rgba(37,99,168,0.3);
  }
  .scale-label-wrapper {
    position: absolute;
    top: 100%;
    width: 100%;
    text-align: center;
    margin-top: 12px;
  }
  .scale-label {
    font-size: 0.7em;
    font-weight: 700;
    color: var(--text-sub);
    line-height: 1.3;
    white-space: pre-wrap;
  }
  .scale-option input[type="radio"]:checked ~ .scale-label-wrapper .scale-label {
    color: var(--blue-mid);
  }

  /* ── Buttons ── */
  .btn-submit {
    display: block;
    width: 100%;
    padding: 18px;
    background: var(--blue-deep);
    color: var(--white);
    font-family: 'Noto Sans JP', sans-serif;
    font-size: 1.1em;
    font-weight: 700;
    letter-spacing: 0.1em;
    border: none;
    border-radius: 12px;
    cursor: pointer;
    box-shadow: 0 6px 20px rgba(26,58,92,0.2);
    transition: background 0.2s, transform 0.1s;
  }
  .btn-submit:hover { background: var(--blue-mid); transform: translateY(-2px); }
  .btn-submit:active { transform: translateY(0); }
  .submit-btn-wrapper { margin-top: 40px; margin-bottom: 20px; }
  
  .btn-share {
    background: linear-gradient(45deg, #f09433 0%, #e6683c 25%, #dc2743 50%, #cc2366 75%, #bc1888 100%);
    margin-top: 15px;
  }
  .btn-share:hover {
    background: linear-gradient(45deg, #e6683c 0%, #dc2743 25%, #cc2366 50%, #bc1888 75%, #f09433 100%);
  }

  .btn-x {
    background: #000000;
    margin-top: 15px;
  }
  .btn-x:hover {
    background: #333333;
  }

  .btn-disabled {
    background: var(--gray-soft);
    cursor: not-allowed;
    box-shadow: none;
  }
  .btn-disabled:hover { background: var(--gray-soft); transform: none; }

  /* ── Result Area ── */
  #result-area {
    display: none;
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 16px 48px rgba(26,58,92,0.18);
    animation: fadeSlideUp 0.5s ease both;
    background: var(--white);
    position: relative;
    margin-bottom: 20px;
  }
  .result-hero {
    padding: 40px 20px 30px;
    text-align: center;
    color: var(--white);
  }
  .result-code-badge {
    display: inline-block;
    font-family: 'Josefin Sans', sans-serif;
    font-size: 0.85em;
    font-weight: 700;
    letter-spacing: 0.2em;
    background: rgba(255,255,255,0.2);
    border: 1px solid rgba(255,255,255,0.4);
    padding: 6px 20px;
    border-radius: 99px;
    margin-bottom: 15px;
  }
  .result-type-name {
    font-size: clamp(1.4em, 5vw, 2em);
    font-weight: 900;
    line-height: 1.3;
  }
  .result-body { padding: 30px 20px 40px; }
  .result-desc {
    font-size: 1.05em;
    line-height: 1.7;
    color: var(--text-main);
    margin-bottom: 25px;
    padding-bottom: 25px;
    border-bottom: 1px solid var(--gray-line);
  }

  /* 画像化時に色が飛ばないためのソリッド指定と2段構成 */
  .job-box {
    background: #f0f7ff; 
    border-radius: 12px;
    padding: 20px;
    border-left: 4px solid #2563a8;
    display: flex;
    flex-direction: column;
    gap: 15px;
  }
  .job-box-section {
    display: flex;
    flex-direction: column;
  }
  .job-box-divider {
    height: 1px;
    background-color: #d8e8f5;
    margin: 5px 0;
  }
  .job-label {
    font-size: 0.85em;
    font-weight: 900; 
    color: #1a3a5c; 
    margin-bottom: 8px;
    display: block;
  }
  .job-text { 
    font-size: 1em; 
    color: #333333; 
    line-height: 1.6; 
    font-weight: 700; 
  }

  .share-hashtags {
    display: none;
    text-align: center;
    font-size: 1.1em;
    font-weight: 900;
    color: var(--blue-mid);
    margin-top: 20px;
    padding-top: 20px;
    border-top: 2px dashed var(--gray-line);
    letter-spacing: 0.05em;
  }

  /* ── Footer ── */
  .app-footer {
    text-align: left;
    margin-top: 30px;
    padding: 20px;
    color: var(--text-sub);
    border-top: 1px solid rgba(37,99,168,0.1);
    background: rgba(255, 255, 255, 0.4);
    border-radius: 12px;
    font-size: 0.75em;
    line-height: 1.6;
  }
  .app-footer h4 {
    font-size: 1.1em;
    color: var(--blue-deep);
    margin-bottom: 6px;
  }
  .app-footer p {
    margin-bottom: 15px;
  }
  .app-footer .copyright {
    text-align: center;
    font-family: 'Josefin Sans', sans-serif;
    font-size: 1.1em;
    margin-top: 20px;
    margin-bottom: 0;
  }

  /* ── Animations ── */
  @keyframes fadeSlideDown { from { opacity: 0; transform: translateY(-15px); } to { opacity: 1; transform: translateY(0); } }
  @keyframes fadeSlideUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
  @keyframes slideDownFade { from { opacity: 0; transform: translateY(-10px); } to { opacity: 1; transform: translateY(0); } }
</style>
